@page  "/units/create"
@inject IBLService blService;
@inject NavigationManager NavMan;
@using Blackout.Components.Pages.Components
@using Microsoft.IdentityModel.Tokens

<h3>Create New Unit</h3>

<UnitForm OnSave="CreateUnit"/>

@code {
    // parent no longer keeps its own Unit instance; it receives
    // the filled object from the child via the OnSave callback.
    public string errorMessage { get; set; } = string.Empty;

    private async Task CreateUnit(Unit unit)
    {
        // the `unit` parameter comes from the form component and will
        // have the ID and other fields filled in by the user.
        await blService.AddUnitAsync(unit);
        NavMan.NavigateTo("/units/" + unit.UnitID);
    }
}